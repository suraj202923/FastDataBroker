{
  "app": {
    "name": "FastDataBroker",
    "version": "0.1.16",
    "environment": "staging"
  },
  "server": {
    "bind_address": "0.0.0.0",
    "port": 6379,
    "cert_path": "/etc/fastdatabroker/certs/cert.pem",
    "key_path": "/etc/fastdatabroker/certs/key.pem",
    "enable_tls": true,
    "max_connections": 10000,
    "max_streams": 1000000,
    "idle_timeout_ms": 45000,
    "request_timeout_secs": 60,
    "enable_metrics": true,
    "metrics_interval_secs": 60
  },
  "logging": {
    "level": "info",
    "format": "json",
    "output": "both",
    "file_path": "/var/log/fastdatabroker/staging.log",
    "include_target": true,
    "include_thread_ids": false
  },
  "features": {
    "multi_tenancy": true,
    "authentication": true,
    "rate_limiting": true,
    "persistence": true,
    "clustering": true
  },
  "tenants": [
    {
      "tenant_id": "staging-acme",
      "tenant_name": "ACME Corporation - Staging",
      "description": "ACME staging tenant for pre-production testing",
      "api_key_prefix": "sk_staging_acme_",
      "rate_limit_rps": 25000,
      "max_connections": 2500,
      "max_message_size": 26214400,
      "retention_days": 30,
      "features": {
        "priority_queue": true,
        "scheduled_messages": true,
        "routing": true,
        "webhooks": true,
        "clustering": true,
        "metrics": true,
        "persistence": true
      },
      "metadata": {
        "owner": "acme-platform",
        "tier": "premium",
