# FastDataBroker Admin API - Environment Configuration

# Logging Level (trace, debug, info, warn, error)
RUST_LOG=info

# Server Configuration
SERVER_ADDR=0.0.0.0:8080
BROKER_URL=http://localhost:9092

# API Authentication Keys (comma-separated, change for production!)
ADMIN_API_KEYS=admin-key-default-change-me,secondary-admin-key

# Storage Configuration
STORAGE_PATH=./tenants

# Cache Configuration  
CACHE_CAPACITY=1000

# Timeout Configuration (in seconds)
REQUEST_TIMEOUT=30
CONNECTION_TIMEOUT=10

# TLS/HTTPS (optional, not implemented yet - for future use)
# ENABLE_TLS=false
# TLS_CERT_PATH=/path/to/cert.pem
# TLS_KEY_PATH=/path/to/key.pem

# Rate Limiting (future enhancement)
# RATE_LIMIT_RPS=1000
# RATE_LIMIT_BURST=2000
