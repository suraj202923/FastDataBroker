{
  "app": {
    "name": "FastDataBroker",
    "version": "0.1.16",
    "environment": "production"
  },
  "server": {
    "bind_address": "0.0.0.0",
    "port": 6379,
    "cert_path": "/etc/fastdatabroker/certs/cert.pem",
    "key_path": "/etc/fastdatabroker/certs/key.pem",
    "enable_tls": true,
    "max_connections": 50000,
    "max_streams": 10000000,
    "idle_timeout_ms": 60000,
    "request_timeout_secs": 120,
    "enable_metrics": true,
    "metrics_interval_secs": 300
  },
  "logging": {
    "level": "warn",
    "format": "json",
    "output": "both",
    "file_path": "/var/log/fastdatabroker/app.log",
    "include_target": false,
    "include_thread_ids": false
  },
  "features": {
    "multi_tenancy": true,
    "authentication": true,
    "rate_limiting": true,
    "persistence": true,
    "clustering": true
  },
  "tenants": [
    {
      "tenant_id": "acme-corp",
      "tenant_name": "ACME Corporation",
      "description": "ACME Corp production tenant - HIGH PRIORITY",
      "api_key_prefix": "sk_prod_acme_",
      "rate_limit_rps": 50000,
      "max_connections": 5000,
      "max_message_size": 52428800,
      "retention_days": 90,
      "features": {
        "priority_queue": true,
        "scheduled_messages": true,
        "routing": true,
        "webhooks": true,
        "clustering": true,
        "metrics": true,
        "persistence": true
      },
      "metadata": {
        "owner": "acme-platform",
        "tier": "premium",
