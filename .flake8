[flake8]
# Ignore non-critical style issues in example/test files
ignore = W293, W291, F541, F401
# Only fail on critical errors in strict mode
select = E9, F63, F7, F82, E722
max-complexity = 10
max-line-length = 127

# Exclude common non-code directories
exclude = 
    .git,
    __pycache__,
    build,
    dist,
    .venv,
    venv,
    *.egg-info,
    .pytest_cache,
    node_modules
