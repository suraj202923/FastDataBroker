{
  "app": {
    "name": "FastDataBroker",
    "version": "0.1.16",
    "environment": "development"
  },
  "server": {
    "bind_address": "0.0.0.0",
    "port": 6379,
    "cert_path": "./certs/cert.pem",
    "key_path": "./certs/key.pem",
    "enable_tls": false,
    "max_connections": 10000,
    "max_streams": 1000000,
    "idle_timeout_ms": 30000,
    "request_timeout_secs": 30,
    "enable_metrics": true,
    "metrics_interval_secs": 60
  },
  "logging": {
    "level": "info",
    "format": "text",
    "output": "console",
    "file_path": null,
    "include_target": true,
    "include_thread_ids": true
  },
  "features": {
    "multi_tenancy": true,
    "authentication": true,
    "rate_limiting": true,
    "persistence": true,
    "clustering": false
  },
  "tenants": [
    {
      "tenant_id": "default",
      "tenant_name": "Default Tenant",
      "description": "Default tenant for development/testing",
      "api_key_prefix": "sk_prod_default_",
      "rate_limit_rps": 10000,
      "max_connections": 1000,
      "max_message_size": 10485760,
      "retention_days": 7,
      "features": {
        "priority_queue": true,
        "scheduled_messages": true,
        "routing": true,
        "webhooks": true,
        "clustering": false,
        "metrics": true,
        "persistence": true
      },
      "metadata": {
        "owner": "platform-team",
        "tier": "standard"
      },
      "enabled": true
    },
    {
      "tenant_id": "acme-corp",
      "tenant_name": "ACME Corporation",
      "description": "ACME Corp production tenant",
      "api_key_prefix": "sk_prod_acme_",
      "rate_limit_rps": 5000,
      "max_connections": 500,
      "max_message_size": 5242880,
      "retention_days": 30,
      "features": {
        "priority_queue": true,
        "scheduled_messages": true,
        "routing": true,
        "webhooks": true,
        "clustering": true,
        "metrics": true,
        "persistence": true
      },
      "metadata": {
        "owner": "acme-devops",
        "tier": "premium",
        "region": "us-east-1"
      },
      "enabled": true
    },
    {
      "tenant_id": "startup-xyz",
      "tenant_name": "Startup XYZ",
      "description": "Early-stage startup tenant",
      "api_key_prefix": "sk_prod_xyz_",
      "rate_limit_rps": 1000,
      "max_connections": 100,
      "max_message_size": 1048576,
      "retention_days": 7,
      "features": {
        "priority_queue": true,
        "scheduled_messages": false,
        "routing": true,
        "webhooks": false,
        "clustering": false,
        "metrics": true,
        "persistence": true
      },
      "metadata": {
        "owner": "xyz-owner",
        "tier": "starter",
        "onboarded_date": "2026-04-01"
      },
      "enabled": true
    }
  ]
}

