{
  "name": "@fastdatabroker/sdk",
  "version": "0.1.12",
  "description": "FastDataBroker JavaScript/TypeScript SDK for messaging and notifications",
  "main": "dist/fastdatabroker.js",
  "types": "dist/fastdatabroker.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts",
    "docs": "typedoc src",
    "prepublishOnly": "npm run build && npm run test"
  },
  "keywords": [
    "FastDataBroker",
    "messaging",
    "notifications",
    "email",
    "websocket",
    "push",
    "webhook",
    "async",
    "quic"
  ],
  "author": "FastDataBroker Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/suraj202923/FastDataBroker.git",
    "directory": "sdks/javascript"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "jest": "^29.5.0",
    "prettier": "^3.0.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.0.0",
    "typedoc": "^0.24.0"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}
