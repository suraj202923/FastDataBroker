{
  "server": {
    "host": "0.0.0.0",
    "port": 6000,
    "protocol": "QUIC",
    "tls_version": "1.3",
    "max_idle_timeout_ms": 30000,
    "max_concurrent_streams": 1000,
    "max_datagram_size": 1200
  },
  "storage": {
    "mode": "hybrid",
    "sled": {
      "enabled": true,
      "path": "/data/sled",
      "cache_capacity": 1073741824,
      "compression": true,
      "compression_factor": 5,
      "use_compression": true,
      "flush_every_ms": 500,
      "snapshot_after_ops": 1000000
    },
    "json": {
      "enabled": true,
      "tenants_path": "/data/tenants",
      "create_if_missing": true,
      "backup_enabled": true,
      "backup_path": "/backups",
      "backup_retention_days": 7,
      "backup_schedule_utc_hour": 2,
      "backup_schedule_utc_minute": 0
    }
  },
  "cache": {
    "tenant_config": {
      "enabled": true,
      "max_size_mb": 50,
      "reload_interval_seconds": 3600,
      "hot_reload": true
    },
    "metrics": {
      "enabled": true,
      "max_entries_per_tenant": 1000,
      "flush_interval_ms": 100,
      "memory_limit_mb": 100
    },
    "psk_verification": {
      "enabled": true,
      "ttl_seconds": 86400,
      "max_cached_entries": 10000,
      "lru_mode": true
    }
  },
  "authentication": {
    "method": "PSK",
    "psk_hash_algorithm": "SHA256",
    "psk_rotation_enabled": true,
    "psk_rotation_days": 90,
    "require_tls": true,
    "min_psk_length": 32
  },
  "rate_limiting": {
    "enabled": true,
    "default_rps": 1000,
    "burst_multiplier": 1.5,
    "window_size_ms": 1000,
    "per_tenant_override": true
  },
  "logging": {
    "ndjson": {
      "enabled": true,
      "path": "/logs/app.log",
      "buffer_size_mb": 10,
      "flush_interval_ms": 50,
      "sync_on_error": true
    },
    "rotation": {
      "enabled": true,
      "schedule_utc_hour": 0,
      "schedule_utc_minute": 0,
      "keep_live_files": 3
    },
    "archive": {
      "enabled": true,
      "format": "parquet",
      "compression": "snappy",
      "compression_level": 5,
      "path": "/logs/archive",
      "schedule_utc_hour": 1,
      "schedule_utc_minute": 0,
      "retention_days": 30,
      "cleanup_batch_size": 1000
    },
    "level": "info",
    "include_request_headers": false,
    "include_request_body": false
  },
  "monitoring": {
    "enabled": true,
    "health_check_interval_ms": 5000,
    "metrics_path": "/metrics",
    "prometheus_enabled": true,
    "hot_reload_enabled": true
  },
  "resilience": {
    "connection_timeout_ms": 10000,
    "read_timeout_ms": 30000,
    "write_timeout_ms": 30000,
    "max_connections_per_tenant": 100,
    "max_queue_size_per_tenant": 1000000,
    "overflow_strategy": "DROP_OLDEST",
    "circuit_breaker": {
      "enabled": true,
      "failure_threshold": 100,
      "success_threshold": 50,
      "timeout_ms": 60000
    }
  },
  "performance": {
    "worker_threads": 0,
    "worker_queue_size": 10000,
    "batch_size": 100,
    "enable_vectored_io": true,
    "enable_tcp_nodelay": true,
    "enable_zero_copy": true
  },
  "admin_api": {
    "enabled": true,
    "host": "127.0.0.1",
    "port": 3000,
    "auth_required": true,
    "auth_token": "changeme_in_production",
    "cors_enabled": false,
    "cors_origins": []
  },
  "clustering": {
    "enabled": false,
    "node_id": "node-1",
    "cluster_name": "fastdatabroker-cluster",
    "peer_discovery": "static",
    "peers": [],
    "gossip_interval_ms": 1000,
    "sync_interval_ms": 5000
  },
  "security": {
    "tls": {
      "cert_path": "/certs/server.crt",
      "key_path": "/certs/server.key",
      "ca_cert_path": null,
      "verify_client_cert": false,
      "session_resumption": true
    },
    "rate_limit_by_ip": false,
    "ip_whitelist_enabled": false,
    "ip_whitelist": [],
    "ip_blacklist_enabled": false,
    "ip_blacklist": []
  },
  "features": {
    "priority_queue": true,
    "message_compression": true,
    "message_encryption": false,
    "message_signing": false,
    "dead_letter_queue": true,
    "message_deduplication": true,
    "ordered_delivery": true
  },
  "deployment": {
    "environment": "production",
    "graceful_shutdown_timeout_ms": 30000,
    "startup_init_timeout_ms": 60000,
    "config_watch_enabled": true,
    "config_watch_interval_ms": 5000
  }
}
